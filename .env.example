# Supabase
# These are copied from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# App-level admin gate for the internal builder.
# Keep this different from client-facing Pink58 passwords.
RECAP_ADMIN_PASSWORD=Admin1

# Optional once the production domain is connected.
NEXT_PUBLIC_APP_URL=https://recaps.slamsocial.biz
